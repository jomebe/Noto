# OpenAI API Configuration for AI-powered insights
# Get your API key from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk_test_your_api_key_here

# Optional: Specify the OpenAI model to use (defaults to gpt-4o-mini)
# Models: gpt-4o-mini, gpt-4o, gpt-4-turbo, gpt-3.5-turbo
VITE_OPENAI_MODEL=gpt-4o-mini
